# FlowSpeak backend public beta template
# Use only for temporary external testing while auth is not finalized.

PORT=3000
HOST=0.0.0.0
REQUIRE_AUTH=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
# Flex mode model routing
OPENAI_MODEL_FLEX_SHORT=gpt-4.1-nano
OPENAI_MODEL_FLEX_LONG=gpt-4.1-mini
OPENAI_MODEL_FLEX_LONG_CHARS=420
OPENAI_MODEL_FLEX_LONG_WORDS=70
OPENAI_MODEL_FLEX_EMAIL_FORCE_LONG=true
DEFAULT_TARGET_LANGUAGE=nb-NO

# Allow your landing page or use * during early desktop-only beta.
ALLOWED_ORIGINS=*

# Keep beta simple: no billing, no Supabase sync required.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAN_MAP={}

# Perf
FASTPATH_CACHE_TTL_MS=10000
FASTPATH_CACHE_MAX_ITEMS=1500
POLISH_LOCAL_FASTPATH_ENABLED=true
POLISH_LOCAL_FASTPATH_MAX_CHARS=90
POLISH_LOCAL_FASTPATH_MAX_WORDS=18
