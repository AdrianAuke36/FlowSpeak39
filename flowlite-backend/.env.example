PORT=3000
HOST=0.0.0.0

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-nano
DEFAULT_TARGET_LANGUAGE=nb-NO
OPENAI_MAX_TOKENS_POLISH=96
OPENAI_MAX_TOKENS_POLISH_SHORT=72
OPENAI_MAX_TOKENS_POLISH_TRANSLATE=80
OPENAI_MAX_TOKENS_POLISH_SUBJECT=48
OPENAI_MAX_TOKENS_POLISH_EMAIL_BODY=144
OPENAI_MAX_TOKENS_REWRITE=128
POLISH_LOCAL_FASTPATH_ENABLED=true
POLISH_LOCAL_FASTPATH_MAX_CHARS=90
POLISH_LOCAL_FASTPATH_MAX_WORDS=18

# Comma-separated list, example:
# FLOWSPEAK_API_TOKENS=fs_user_abc123,fs_user_def456
FLOWSPEAK_API_TOKENS=

# Optional JWT auth (HS256). If set, Bearer JWTs are accepted on /polish.
# You can configure both static tokens and JWT in parallel.
# FLOWSPEAK_JWT_SECRET=replace-with-long-random-secret
FLOWSPEAK_JWT_SECRET=
# Optional key rotation list (comma-separated):
# FLOWSPEAK_JWT_SECRETS=secret_old,secret_current
# Optional strict checks:
# FLOWSPEAK_JWT_AUDIENCE=flowspeak-client
# FLOWSPEAK_JWT_ISSUER=flowspeak-auth
# JWT_CLOCK_SKEW_SEC=20

# Supabase JWT verify (recommended for Supabase Auth access tokens)
# SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=
# Optional explicit override:
# SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_TIMEOUT_MS=1500
SUPABASE_JWKS_COOLDOWN_MS=30000

# Stripe + Supabase subscription sync (optional)
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_TOLERANCE_SEC=300
# JSON mapping from Stripe price ID to plan name.
# Example: STRIPE_PRICE_PLAN_MAP={"price_pro_123":"pro","price_team_456":"team"}
STRIPE_PRICE_PLAN_MAP={}

# Supabase REST sync target (service role required)
# Optional override:
# SUPABASE_REST_URL=https://your-project-ref.supabase.co/rest/v1
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BILLING_TABLE=billing_subscriptions
SUPABASE_USER_COLUMN=user_id
SUPABASE_STRIPE_CUSTOMER_COLUMN=stripe_customer_id

# Optional auth debug logging
# AUTH_DEBUG=true

REQUIRE_AUTH=true

# Optional CORS allow-list. Use * for desktop-only/private use.
# Example: ALLOWED_ORIGINS=https://app.flowspeak.no,https://admin.flowspeak.no
ALLOWED_ORIGINS=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AUTH=120
RATE_LIMIT_MAX_PUBLIC=30
# Optional plan-based auth limits (JWT claim "plan": free|pro|team|enterprise)
RATE_LIMIT_MAX_AUTH_FREE=120
RATE_LIMIT_MAX_AUTH_PRO=240
RATE_LIMIT_MAX_AUTH_TEAM=360
RATE_LIMIT_MAX_AUTH_ENTERPRISE=600
FASTPATH_CACHE_TTL_MS=10000
FASTPATH_CACHE_MAX_ITEMS=1500
METRICS_HISTORY_MAX=2000

# Optional Redis-backed global rate limit (recommended for multi-instance deployments)
# RATE_LIMIT_REDIS_URL=https://<upstash-host>
# RATE_LIMIT_REDIS_TOKEN=<token>
# RATE_LIMIT_REDIS_PREFIX=flowspeak:rl

# Optional: set to true only while debugging prompts/outputs.
# Keep false in production to avoid content logging.
# LOG_REQUEST_CONTENT=false

# In-memory dedupe TTL fallback for webhook events (ms)
# WEBHOOK_DEDUP_TTL_MS=86400000
