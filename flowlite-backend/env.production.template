# FlowSpeak backend production template
# Fill values and rename to .env on the production host.

PORT=3000
HOST=0.0.0.0
REQUIRE_AUTH=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
# Flex mode model routing (short input -> short model, long/complex input -> long model)
OPENAI_MODEL_FLEX_SHORT=gpt-4.1-nano
OPENAI_MODEL_FLEX_LONG=gpt-4.1-mini
OPENAI_MODEL_FLEX_LONG_CHARS=420
OPENAI_MODEL_FLEX_LONG_WORDS=70
OPENAI_MODEL_FLEX_EMAIL_FORCE_LONG=true
DEFAULT_TARGET_LANGUAGE=nb-NO
OPENAI_MAX_TOKENS_POLISH=96
OPENAI_MAX_TOKENS_POLISH_SHORT=72
OPENAI_MAX_TOKENS_POLISH_MEANING=160
OPENAI_MAX_TOKENS_POLISH_TRANSLATE=80
OPENAI_MAX_TOKENS_POLISH_SUBJECT=48
OPENAI_MAX_TOKENS_POLISH_EMAIL_BODY=144
OPENAI_MAX_TOKENS_REWRITE=128

# Optional Groq STT test settings (used by scripts/stt-ab.mjs)
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_RESPONSE_FORMAT=verbose_json
GROQ_STT_TEMPERATURE=0

# Supabase JWT verification
SUPABASE_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# Optional explicit overrides:
# SUPABASE_JWT_ISSUER=https://<project>.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# Billing sync (required only if Stripe/Pro is enabled)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BILLING_TABLE=billing_subscriptions
SUPABASE_USER_COLUMN=user_id
SUPABASE_STRIPE_CUSTOMER_COLUMN=stripe_customer_id

# Stripe (required only if Stripe/Pro is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAN_MAP={}

# CORS (must include your landing/web app origins)
ALLOWED_ORIGINS=

# Optional perf tuning
FASTPATH_CACHE_TTL_MS=10000
FASTPATH_CACHE_MAX_ITEMS=1500
POLISH_LOCAL_FASTPATH_ENABLED=true
POLISH_LOCAL_FASTPATH_MAX_CHARS=90
POLISH_LOCAL_FASTPATH_MAX_WORDS=18

# Optional daily authenticated usage caps (0 disables the daily cap for that plan)
DAILY_USAGE_MAX_AUTH_FREE=1200
DAILY_USAGE_MAX_AUTH_PRO=5000
DAILY_USAGE_MAX_AUTH_TEAM=10000
DAILY_USAGE_MAX_AUTH_ENTERPRISE=25000
DAILY_USAGE_TABLE=daily_usage_counters
DAILY_USAGE_SUPABASE_RETRY_MAX=4
ERROR_HISTORY_MAX=250
