# FlowSpeak backend production template
# Fill values and rename to .env on the production host.

PORT=3000
HOST=0.0.0.0
REQUIRE_AUTH=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
DEFAULT_TARGET_LANGUAGE=nb-NO

# Supabase JWT verification
SUPABASE_URL=
SUPABASE_JWT_AUDIENCE=authenticated

# Optional explicit overrides:
# SUPABASE_JWT_ISSUER=https://<project>.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json

# Billing sync (required only if Stripe/Pro is enabled)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BILLING_TABLE=billing_subscriptions
SUPABASE_USER_COLUMN=user_id
SUPABASE_STRIPE_CUSTOMER_COLUMN=stripe_customer_id

# Stripe (required only if Stripe/Pro is enabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAN_MAP={}

# CORS (must include your landing/web app origins)
ALLOWED_ORIGINS=

# Optional perf tuning
FASTPATH_CACHE_TTL_MS=10000
FASTPATH_CACHE_MAX_ITEMS=1500
POLISH_LOCAL_FASTPATH_ENABLED=true
POLISH_LOCAL_FASTPATH_MAX_CHARS=90
POLISH_LOCAL_FASTPATH_MAX_WORDS=18
